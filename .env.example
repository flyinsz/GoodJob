TRADE_OBSERVATION_CURSOR_SECRET=replace_with_another_32_plus_character_random_key
MARKET_OPPORTUNITY_CURSOR_SECRET=replace_with_a_distinct_32_plus_character_random_key
PROSPECT_RUN_IDEMPOTENCY_SECRET=replace_with_a_distinct_32_plus_character_random_key
PROSPECT_RUN_CURSOR_SECRET=replace_with_a_distinct_32_plus_character_random_key
PROSPECT_EXECUTION_CLAIM_SECRET=replace_with_a_distinct_32_plus_character_random_key
PROSPECT_WORKER_ENABLED=true
PROSPECT_WORKER_POLL_MS=1000
PROSPECT_EXECUTION_DB_LOCK_TIMEOUT_MS=5000
PROSPECT_CANDIDATE_DB_LOCK_TIMEOUT_MS=5000
REDIS_URL=
PROSPECT_QUEUE_REQUIRED=false
PROSPECT_QUEUE_SYNC_MS=5000
PROSPECT_REDIS_CONNECT_TIMEOUT_MS=3000
ORGANIZATION_IDENTITY_MASTER_SECRET=replace_with_a_distinct_32_plus_character_random_key
PROSPECT_SOURCE_RAW_ENVELOPE_SECRET=replace_with_a_distinct_32_plus_character_random_key
PROSPECT_COVERAGE_MASTER_SECRET=replace_with_a_distinct_32_plus_character_random_key
